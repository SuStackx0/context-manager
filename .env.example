# ---- Database ----
DATABASE_URL=sqlite:///./data/context.db

# ---- Vector store (FAISS) ----
FAISS_INDEX_PATH=./data/faiss.index

# ---- Providers ----
# LLM_PROVIDER: "local" (HF transformers) or "fake" (deterministic, no torch)
LLM_PROVIDER=local
LLM_MODEL_NAME=Qwen/Qwen2.5-0.5B-Instruct
LLM_MAX_NEW_TOKENS=256

# EMBEDDING_PROVIDER: "local" (sentence-transformers) or "fake"
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIM=384

# ---- Token budgeting ----
MAX_CONTEXT_TOKENS=2048
COMPRESS_TOKEN_THRESHOLD=3000
RECENT_MESSAGES_KEEP=10
RETRIEVAL_TOP_K=5
RETRIEVAL_OVERFETCH=5

# ---- Misc ----
LOG_LEVEL=INFO
API_PREFIX=/api/v1
